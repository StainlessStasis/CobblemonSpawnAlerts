{
  "schemaVersion": 1,
  "id": "cobblemon_spawn_alerts",
  "version": "${version}",
  "name": "Cobblemon Spawn Alerts",
  "description": "A highly customizable sidemod for Cobblemon 1.7.0+ to alert you when a certain Pokemon spawns",
  "authors": [
    "Stasis, the Shattered"
  ],
  "license": "MIT License",
  "icon": "assets/cobblemon_spawn_alerts/icon.png",
  "environment": "*",
  "mixins": [
    "common.mixins.json",
    "fabric.mixins.json"
  ],
  "accessWidener": "cobblemon-spawn-alerts.accesswidener",
  "entrypoints": {
    "main": [
      "io.github.stainlessstasis.CSAFabric"
    ],
    "client": [
      "io.github.stainlessstasis.CSAFabricClient"
    ],
    "journeymap": [
      "io.github.stainlessstasis.JourneymapFabricPlugin"
    ]
  },
  "depends": {
    "minecraft": "1.21.1",
    "cobblemon": ">=1.7.0",
    "emberstextapi": ">=2.5.0"
  }
}